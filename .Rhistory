View(risk_2024_muni)
# prepara cada nível
risco_pais_prep <- risk_2024_country %>%
filter(virus == "Dengue") %>%
mutate(location = country, level = "Country") %>%
select(level, location, epi_week, calendar_year_week, riskassessment)
risco_estado_prep <- risk_2024_state %>%
filter(virus == "Dengue") %>%
mutate(location = uf, level = "State") %>%
select(level, location, epi_week, calendar_year_week, riskassessment)
risco_muni_prep <- risk_2024_muni %>%
filter(virus == "Dengue") %>%
mutate(location = muni_name, level = "Municipality") %>%
select(level, location, ibge, epi_week, calendar_year_week, riskassessment)
View(risco_pais_prep)
risco_pais_prep <- risk_2024_country %>%
filter(virus == "Dengue") %>%
mutate(location = country, level = "Country") %>%
select(level, location, epi_week, calendar_year_week, riskassessment)
risco_estado_prep <- risk_2024_state %>%
filter(virus == "Dengue") %>%
mutate(location = uf, level = "State") %>%
select(level, location, epi_week, calendar_year_week, riskassessment)
risco_muni_prep <- risk_2024_muni %>%
filter(virus == "Dengue") %>%
mutate(location = muni_name, level = "Municipality") %>%
select(level, location, ibge, epi_week, calendar_year_week, riskassessment)
# junta todos os níveis
all_levels_risk <- bind_rows(risco_pais_prep, risco_estado_prep, risco_muni_prep)
# calcula métricas por localidade
summary_data <- all_levels_risk %>%
group_by(level, location) %>%
summarise(
first_alert_week_epi    = min(epi_week[riskassessment == 2], na.rm = TRUE),
first_epidemic_week_epi = min(epi_week[riskassessment == 3], na.rm = TRUE),
max_consecutive_level2 = {
rle_res <- rle(riskassessment == 2)
if (any(rle_res$values)) max(rle_res$lengths[rle_res$values]) else 0
},
max_consecutive_level3 = {
rle_res <- rle(riskassessment == 3)
if (any(rle_res$values)) max(rle_res$lengths[rle_res$values]) else 0
},
max_consecutive_level2_or_3 = {
rle_res <- rle(riskassessment %in% c(2, 3))
if (any(rle_res$values)) max(rle_res$lengths[rle_res$values]) else 0
},
.groups = "drop"
)
# lookup para converter semana epidemiológica em semana calendário
week_lookup <- all_levels_risk %>%
select(location, epi_week, calendar_year_week) %>%
distinct()
# monta a tabela final
summary_table <- summary_data %>%
left_join(week_lookup, by = c("location", "first_alert_week_epi"    = "epi_week")) %>%
rename(first_alert_cal = calendar_year_week) %>%
left_join(week_lookup, by = c("location", "first_epidemic_week_epi" = "epi_week")) %>%
rename(first_epidemic_cal = calendar_year_week) %>%
mutate(
first_alert_display    = if_else(is.infinite(first_alert_week_epi),    "Sem Alerta",   first_alert_cal),
first_epidemic_display = if_else(is.infinite(first_epidemic_week_epi), "Sem Epidemia", first_epidemic_cal)
) %>%
select(
`Nível`                                    = level,
`Localidade`                               = location,
`Primeira Semana de Alerta (nível 2)`      = first_alert_display,
`Máx. Semanas Consecutivas (nível 2)`      = max_consecutive_level2,
`Primeira Semana de Epidemia (nível 3)`    = first_epidemic_display,
`Máx. Semanas Consecutivas (nível 3)`      = max_consecutive_level3,
`Máx. Semanas Consecutivas (nível 2 ou 3)` = max_consecutive_level2_or_3
)
print(summary_table)
View(summary_table)
emergency_country <- tibble(
label       = "02/02/2024",
date_issued = dmy("02/02/2024")
) %>%
mutate(
year               = year(date_issued),
week               = week(date_issued),
calendar_year_week = paste0(year, "w", as.integer(week))
) %>%
left_join(epiweek40, by = "calendar_year_week")
# declarações estaduais
emergency_state <- tribble(
~uf,  ~date_issued,
"AC", "05/01/2024",
"DF", "25/01/2024",
"GO", "02/02/2024",
"ES", "21/02/2024",
"RJ", "21/02/2024",
"SC", "22/02/2024",
"MG", "26/02/2024",
"AP", "28/02/2024",
"SP", "05/03/2024",
"RS", "12/03/2024",
"PR", "14/03/2024"
) %>%
mutate(
date_issued        = dmy(date_issued),
year               = year(date_issued),
week               = week(date_issued),
calendar_year_week = paste0(year, "w", as.integer(week))
) %>%
left_join(epiweek40, by = "calendar_year_week")
# declarações municipais
emergency_muni <- tribble(
~ibge,   ~date_issued,
420540,  "29/11/2023",  # Florianópolis
330455,  "02/02/2024",  # Rio de Janeiro
310620,  "16/02/2024",  # Belo Horizonte
240810,  "01/03/2024",  # Natal
520870,  "13/03/2024",  # Goiânia
355030,  "18/03/2024",  # São Paulo
431490,  "22/04/2024"   # Porto Alegre
) %>%
mutate(
ibge               = as.numeric(ibge),
date_issued        = dmy(date_issued),
year               = year(date_issued),
week               = week(date_issued),
