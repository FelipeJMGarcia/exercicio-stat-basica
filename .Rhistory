inc_acima_p75            = ifelse(incidence_current > high, 1, 0),
inc_acima_p75_4s         = zoo::rollapply(inc_acima_p75, 4, function(x) as.integer(all(x == 1)), fill = 0, align = "right"),
mortes_crescendo         = ifelse(deaths_current > lag(deaths_current, 1), 1, 0),
mortes_crescendo_4s      = zoo::rollapply(mortes_crescendo, 4, function(x) as.integer(all(x == 1)), fill = 0, align = "right"),
letalidade               = ifelse(incidence_current > 0, (deaths_current / incidence_current) > 0.0005, 0),
crescimento_exponencial  = ifelse(incidence_current > 0 & lag(incidence_current, 1) > 0,
log(incidence_current) > log(lag(incidence_current, 1)) & incidence_current > high, 0),
mortes_crescendo_5s      = zoo::rollapply(mortes_crescendo, 5, function(x) as.integer(all(x == 1)), fill = 0, align = "right"),
riskassessment = case_when(
epi_week <= 4                                                             ~ -1L,
(crescimento_exponencial == 1 | mortes_crescendo_5s == 1)                ~  3L,
(inc_acima_p75_4s == 1 | mortes_crescendo_4s == 1 | letalidade == 1)     ~  2L,
inc_entre_mediana_p75_4s == 1                                            ~  1L,
TRUE                                                                      ~  0L
)
)
# adiciona identificadores
risk_2024_country <- risco_pais %>%
mutate(
country        = "Brazil",
virus          = "Dengue",
epi_week       = as.numeric(epi_week),
riskassessment = as.factor(riskassessment)
)
canal_endemico_pais <- arboviruses_country %>%
filter(epi_year >= 2015 & epi_year != 2024) %>%
group_by(epi_week) %>%
summarise(
median_incidence = median(incidence),
high             = quantile(incidence, 0.75),
low              = quantile(incidence, 0.25),
.groups = "drop"
)
